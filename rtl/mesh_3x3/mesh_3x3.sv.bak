`timescale 1ns/1ps

module mesh_3x3 #(
    parameter DATA_WIDTH = 34
)(
    input  wire clk,
    input  wire rst_n
);

    // =======================================================
    // 1. KHAI BÁO MẢNG DÂY KẾT NỐI (3x3)
    // =======================================================
    wire [DATA_WIDTH-1:0] flit_in  [0:2][0:2];
    wire [DATA_WIDTH-1:0] flit_out [0:2][0:2];
    wire                  valid_in [0:2][0:2];
    wire                  valid_out[0:2][0:2];
    wire                  credit_in[0:2][0:2];
    wire                  credit_out[0:2][0:2];

    // =======================================================
    // 2. DÂY ẢO CHO CÁC CỔNG OUTPUT Ở BIÊN (Tránh lỗi Multi-driven)
    // =======================================================
    wire [DATA_WIDTH-1:0] unused_flit_out  [0:2][0:2];
    wire                  unused_valid_out [0:2][0:2];
    wire                  unused_credit_out[0:2][0:2];

    // =======================================================
    // 3. LOGIC KẾT NỐI VÒNG LẶP (Dùng generate chuẩn Verilog)
    // =======================================================
    genvar x, y;
    generate
        for (x = 0; x < 3; x = x + 1) begin : gen_x
            for (y = 0; y < 3; y = y + 1) begin : gen_y
                
                // --- Kết nối EAST - WEST (Chiều X) ---
                if (x < 2) begin
                    // E của (x, y) nối vào W của (x+1, y)
                    assign flit_in [x+1][y] = flit_out [x][y]; 
                    assign valid_in[x+1][y] = valid_out[x][y];
                    assign credit_out[x][y] = credit_in[x+1][y];
                end else begin
                    // Biên phải: Cổng E không dùng -> Credit luôn = 1
                    assign credit_out[x][y] = 1'b1; 
                end

                // --- Kết nối NORTH - SOUTH (Chiều Y) ---
                if (y < 2) begin
                    // S của (x, y) nối vào N của (x, y+1)
                    assign flit_in [x][y+1] = flit_out [x][y];
                    assign valid_in[x][y+1] = valid_out[x][y];
                    assign credit_out[x][y] = credit_in[x][y+1];
                end else begin
                    // Biên dưới: Cổng S không dùng -> Credit luôn = 1
                    assign credit_out[x][y] = 1'b1;
                end

                // --- Đặt giá trị Input mặc định cho các cổng ở biên ---
                // Cổng West (x == 0) - Biên trái
                if (x == 0) begin
                    assign flit_in[x][y] = {DATA_WIDTH{1'b0}};
                    assign valid_in[x][y] = 1'b0;
                end
                
                // Cổng North (y == 0) - Biên trên (Chỉ gán nếu x!=0 để tránh lỗi trùng dây)
                if (y == 0 && x != 0) begin
                    assign flit_in[x][y] = {DATA_WIDTH{1'b0}};
                    assign valid_in[x][y] = 1'b0;
                end
            end
        end
    endgenerate


    // =======================================================
    // 4. INSTANTIATE 9 NODE (2 CPU, 1 SLAVE, 6 TG)
    // =======================================================

    // ---- NODE (0,0): CPU Master 0 ----
    master_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd0), .CURRENT_Y(2'd0),
        .PRIORITY(1'b0),
        .ROM_FILE("D:/project_verilog/noc_riscV/rtl/mesh_3x3/hex/code_master0.hex")
    ) node_00 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in(flit_in[0][0]), .n_valid_in(valid_in[0][0]), .n_credit_out(credit_out[0][0]),
        .n_flit_out(flit_out[0][0]), .n_valid_out(valid_out[0][0]), .n_credit_in(credit_in[0][0]),
        .s_flit_in(flit_in[0][1]), .s_valid_in(valid_in[0][1]), .s_credit_out(credit_out[0][1]),
        .s_flit_out(flit_out[0][1]), .s_valid_out(valid_out[0][1]), .s_credit_in(credit_in[0][1]),
        .e_flit_in(flit_in[1][0]), .e_valid_in(valid_in[1][0]), .e_credit_out(credit_out[1][0]),
        .e_flit_out(flit_out[1][0]), .e_valid_out(valid_out[1][0]), .e_credit_in(credit_in[1][0]),
        .w_flit_in({DATA_WIDTH{1'b0}}), .w_valid_in(1'b0), .w_credit_out(unused_credit_out[0][0]),
        .w_flit_out(unused_flit_out[0][0]), .w_valid_out(unused_valid_out[0][0]), .w_credit_in(1'b1)
    );

    // ---- NODE (0,1): CPU Master 1 ----
    master_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd0), .CURRENT_Y(2'd1),
        .PRIORITY(1'b0),
        .ROM_FILE("D:/project_verilog/noc_riscV/rtl/mesh_3x3/hex/code_master1.hex")
    ) node_01 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in(flit_in[0][1]), .n_valid_in(valid_in[0][1]), .n_credit_out(credit_out[0][1]),
        .n_flit_out(flit_out[0][1]), .n_valid_out(valid_out[0][1]), .n_credit_in(credit_in[0][1]),
        .s_flit_in(flit_in[0][2]), .s_valid_in(valid_in[0][2]), .s_credit_out(credit_out[0][2]),
        .s_flit_out(flit_out[0][2]), .s_valid_out(valid_out[0][2]), .s_credit_in(credit_in[0][2]),
        .e_flit_in(flit_in[1][1]), .e_valid_in(valid_in[1][1]), .e_credit_out(credit_out[1][1]),
        .e_flit_out(flit_out[1][1]), .e_valid_out(valid_out[1][1]), .e_credit_in(credit_in[1][1]),
        .w_flit_in({DATA_WIDTH{1'b0}}), .w_valid_in(1'b0), .w_credit_out(unused_credit_out[0][1]),
        .w_flit_out(unused_flit_out[0][1]), .w_valid_out(unused_valid_out[0][1]), .w_credit_in(1'b1)
    );

    // ---- NODE (0,2): TG 0 ----
    tg_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd0), .CURRENT_Y(2'd2),
        .PRIORITY(1'b0),
        .DEST_X(2'd2), .DEST_Y(2'd2),
        .LOAD_FACTOR(8), .WRITE_PROB(30)
    ) node_02 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in(flit_in[0][2]), .n_valid_in(valid_in[0][2]), .n_credit_out(credit_out[0][2]),
        .n_flit_out(flit_out[0][2]), .n_valid_out(valid_out[0][2]), .n_credit_in(credit_in[0][2]),
        .s_flit_in({DATA_WIDTH{1'b0}}), .s_valid_in(1'b0), .s_credit_out(unused_credit_out[0][2]),
        .s_flit_out(unused_flit_out[0][2]), .s_valid_out(unused_valid_out[0][2]), .s_credit_in(1'b1),
        .e_flit_in(flit_in[1][2]), .e_valid_in(valid_in[1][2]), .e_credit_out(credit_out[1][2]),
        .e_flit_out(flit_out[1][2]), .e_valid_out(valid_out[1][2]), .e_credit_in(credit_in[1][2]),
        .w_flit_in({DATA_WIDTH{1'b0}}), .w_valid_in(1'b0), .w_credit_out(unused_credit_out[0][2]),
        .w_flit_out(unused_flit_out[0][2]), .w_valid_out(unused_valid_out[0][2]), .w_credit_in(1'b1)
    );

    // ---- NODE (1,0): TG 1 ----
    tg_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd1), .CURRENT_Y(2'd0),
        .PRIORITY(1'b0),
        .DEST_X(2'd2), .DEST_Y(2'd2),
        .LOAD_FACTOR(16), .WRITE_PROB(50)
    ) node_10 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in({DATA_WIDTH{1'b0}}), .n_valid_in(1'b0), .n_credit_out(unused_credit_out[1][0]),
        .n_flit_out(unused_flit_out[1][0]), .n_valid_out(unused_valid_out[1][0]), .n_credit_in(1'b1),
        .s_flit_in(flit_in[1][1]), .s_valid_in(valid_in[1][1]), .s_credit_out(credit_out[1][1]),
        .s_flit_out(flit_out[1][1]), .s_valid_out(valid_out[1][1]), .s_credit_in(credit_in[1][1]),
        .e_flit_in(flit_in[2][0]), .e_valid_in(valid_in[2][0]), .e_credit_out(credit_out[2][0]),
        .e_flit_out(flit_out[2][0]), .e_valid_out(valid_out[2][0]), .e_credit_in(credit_in[2][0]),
        .w_flit_in({DATA_WIDTH{1'b0}}), .w_valid_in(1'b0), .w_credit_out(unused_credit_out[1][0]),
        .w_flit_out(unused_flit_out[1][0]), .w_valid_out(unused_valid_out[1][0]), .w_credit_in(1'b1)
    );

    // ---- NODE (1,1): TG 2 (Có Priority=1 để test ưu tiên) ----
    tg_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd1), .CURRENT_Y(2'd1),
        .PRIORITY(1'b1),
        .DEST_X(2'd2), .DEST_Y(2'd2),
        .LOAD_FACTOR(4), .WRITE_PROB(70)
    ) node_11 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in(flit_in[1][1]), .n_valid_in(valid_in[1][1]), .n_credit_out(credit_out[1][1]),
        .n_flit_out(flit_out[1][1]), .n_valid_out(valid_out[1][1]), .n_credit_in(credit_in[1][1]),
        .s_flit_in(flit_in[1][2]), .s_valid_in(valid_in[1][2]), .s_credit_out(credit_out[1][2]),
        .s_flit_out(flit_out[1][2]), .s_valid_out(valid_out[1][2]), .s_credit_in(credit_in[1][2]),
        .e_flit_in(flit_in[2][1]), .e_valid_in(valid_in[2][1]), .e_credit_out(credit_out[2][1]),
        .e_flit_out(flit_out[2][1]), .e_valid_out(valid_out[2][1]), .e_credit_in(credit_in[2][1]),
        .w_flit_in(flit_in[0][1]), .w_valid_in(valid_in[0][1]), .w_credit_out(credit_out[0][1]),
        .w_flit_out(flit_out[0][1]), .w_valid_out(valid_out[0][1]), .w_credit_in(credit_in[0][1])
    );

    // ---- NODE (1,2): TG 3 ----
    tg_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd1), .CURRENT_Y(2'd2),
        .PRIORITY(1'b1),
        .DEST_X(2'd2), .DEST_Y(2'd2),
        .LOAD_FACTOR(12), .WRITE_PROB(80)
    ) node_12 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in(flit_in[1][2]), .n_valid_in(valid_in[1][2]), .n_credit_out(credit_out[1][2]),
        .n_flit_out(flit_out[1][2]), .n_valid_out(valid_out[1][2]), .n_credit_in(credit_in[1][2]),
        .s_flit_in({DATA_WIDTH{1'b0}}), .s_valid_in(1'b0), .s_credit_out(unused_credit_out[1][2]),
        .s_flit_out(unused_flit_out[1][2]), .s_valid_out(unused_valid_out[1][2]), .s_credit_in(1'b1),
        .e_flit_in(flit_in[2][2]), .e_valid_in(valid_in[2][2]), .e_credit_out(credit_out[2][2]),
        .e_flit_out(flit_out[2][2]), .e_valid_out(valid_out[2][2]), .e_credit_in(credit_in[2][2]),
        .w_flit_in(flit_in[0][2]), .w_valid_in(valid_in[0][2]), .w_credit_out(credit_out[0][2]),
        .w_flit_out(flit_out[0][2]), .w_valid_out(valid_out[0][2]), .w_credit_in(credit_in[0][2])
    );

    // ---- NODE (2,0): TG 4 ----
    tg_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd2), .CURRENT_Y(2'd0),
        .PRIORITY(1'b0),
        .DEST_X(2'd2), .DEST_Y(2'd2),
        .LOAD_FACTOR(20), .WRITE_PROB(20)
    ) node_20 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in({DATA_WIDTH{1'b0}}), .n_valid_in(1'b0), .n_credit_out(unused_credit_out[2][0]),
        .n_flit_out(unused_flit_out[2][0]), .n_valid_out(unused_valid_out[2][0]), .n_credit_in(1'b1),
        .s_flit_in(flit_in[2][1]), .s_valid_in(valid_in[2][1]), .s_credit_out(credit_out[2][1]),
        .s_flit_out(flit_out[2][1]), .s_valid_out(valid_out[2][1]), .s_credit_in(credit_in[2][1]),
        .e_flit_in({DATA_WIDTH{1'b0}}), .e_valid_in(1'b0), .e_credit_out(unused_credit_out[2][0]),
        .e_flit_out(unused_flit_out[2][0]), .e_valid_out(unused_valid_out[2][0]), .e_credit_in(1'b1),
        .w_flit_in(flit_in[1][0]), .w_valid_in(valid_in[1][0]), .w_credit_out(credit_out[1][0]),
        .w_flit_out(flit_out[1][0]), .w_valid_out(valid_out[1][0]), .w_credit_in(credit_in[1][0])
    );

    // ---- NODE (2,1): TG 5 ----
    tg_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd2), .CURRENT_Y(2'd1),
        .PRIORITY(1'b0),
        .DEST_X(2'd2), .DEST_Y(2'd2),
        .LOAD_FACTOR(10), .WRITE_PROB(60)
    ) node_21 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in(flit_in[2][1]), .n_valid_in(valid_in[2][1]), .n_credit_out(credit_out[2][1]),
        .n_flit_out(flit_out[2][1]), .n_valid_out(valid_out[2][1]), .n_credit_in(credit_in[2][1]),
        .s_flit_in(flit_in[2][2]), .s_valid_in(valid_in[2][2]), .s_credit_out(credit_out[2][2]),
        .s_flit_out(flit_out[2][2]), .s_valid_out(valid_out[2][2]), .s_credit_in(credit_in[2][2]),
        .e_flit_in({DATA_WIDTH{1'b0}}), .e_valid_in(1'b0), .e_credit_out(unused_credit_out[2][1]),
        .e_flit_out(unused_flit_out[2][1]), .e_valid_out(unused_valid_out[2][1]), .e_credit_in(1'b1),
        .w_flit_in(flit_in[1][1]), .w_valid_in(valid_in[1][1]), .w_credit_out(credit_out[1][1]),
        .w_flit_out(flit_out[1][1]), .w_valid_out(valid_out[1][1]), .w_credit_in(credit_in[1][1])
    );

    // ---- NODE (2,2): SLAVE SHARED RAM ----
    slave_node #(
        .DATA_WIDTH(DATA_WIDTH),
        .CURRENT_X(2'd2), .CURRENT_Y(2'd2),
        .MEM_DEPTH(1024)
    ) node_22 (
        .clk(clk), .rst_n(rst_n),
        .n_flit_in(flit_in[2][2]), .n_valid_in(valid_in[2][2]), .n_credit_out(credit_out[2][2]),
        .n_flit_out(flit_out[2][2]), .n_valid_out(valid_out[2][2]), .n_credit_in(credit_in[2][2]),
        .s_flit_in({DATA_WIDTH{1'b0}}), .s_valid_in(1'b0), .s_credit_out(unused_credit_out[2][2]),
        .s_flit_out(unused_flit_out[2][2]), .s_valid_out(unused_valid_out[2][2]), .s_credit_in(1'b1),
        .e_flit_in({DATA_WIDTH{1'b0}}), .e_valid_in(1'b0), .e_credit_out(unused_credit_out[2][2]),
        .e_flit_out(unused_flit_out[2][2]), .e_valid_out(unused_valid_out[2][2]), .e_credit_in(1'b1),
        .w_flit_in(flit_in[1][2]), .w_valid_in(valid_in[1][2]), .w_credit_out(credit_out[1][2]),
        .w_flit_out(flit_out[1][2]), .w_valid_out(valid_out[1][2]), .w_credit_in(credit_in[1][2])
    );

endmodule