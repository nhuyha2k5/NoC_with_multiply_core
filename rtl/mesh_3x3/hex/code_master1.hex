// Địa chỉ bắt đầu: 0x00000000
// lui x1, 0x8500        -> x1 = 0x85000000 (địa chỉ Slave 1,1)
// addi x2, x0, 0x1234   -> x2 = 0x00001234
// sw x2, 0(x1)          -> ghi 0x1234 vào 0x85000000
// j 0x0000000c          -> nhảy vô tận về lệnh sw
00000000: 850001b7
00000004: 12345113
00000008: 0020a023
0000000c: 0000006f