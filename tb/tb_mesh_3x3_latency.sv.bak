`timescale 1ns/1ps

module tb_mesh_3x3_latency;
    logic clk;
    logic rst_n;

    // Kế thừa các cổng ngõ ra từ file mesh_3x3 của bạn
    wire [31:0] fmax_pc_00, fmax_alu_00, fmax_pc_22, fmax_alu_22, dummy_output;

    // Khởi tạo DUT (Design Under Test)
    mesh_3x3 dut (
        .clk(clk),
        .rst_n(rst_n),
        .fmax_pc_00(fmax_pc_00),
        .fmax_alu_00(fmax_alu_00),
        .fmax_pc_22(fmax_pc_22),
        .fmax_alu_22(fmax_alu_22),
        .dummy_output(dummy_output)
    );

    // Tạo xung nhịp Clk tương đương 50MHz (Chu kỳ 20ns)
    always #10 clk = ~clk;

    // Biến đo đạc thời gian
    realtime send_time;
    realtime receive_time;
    realtime latency_ns;

    initial begin
        clk = 0;
        rst_n = 0;
        #40;
        rst_n = 1; // Tháo Reset
        
        $display("[LATENCY TEST] Bat dau kiem tra do tre truyen dan...");

        // Chờ Master (0,0) phát tín hiệu TX_VALID lên mạng NoC
        fork
            begin
                wait(dut.node_00.u_master0.tx_valid== 1'b1);
                send_time = $realtime;
                $display("[SOURCE (0,0)] Da bom Head Flit vao luc: %0t ns", send_time);
            end
            
            begin
                // Chờ Slave RAM (1,1) nhận được gói tin hợp lệ
                wait(dut.node_11.u_slave.rx_valid == 1'b1);
                receive_time = $realtime;
                $display("[DEST (1,1)] Da nhan Head Flit vao luc: %0t ns", receive_time);
            end
        join

        // Tính toán độ trễ
        latency_ns = receive_time - send_time;
        $display("=================================================");
        $display(" KẾT QUẢ ĐO ĐỘ TRỄ (LATENCY): %0f ns", latency_ns);
        $display(" Tuong duong khoang: %0d chu ky xung nhip.", latency_ns / 20);
        $display("=================================================");
        
        #200;
        $finish;
    end
endmodule