`timescale 1ns/1ps

// Định nghĩa cấu trúc gói tin (Flit)
typedef struct packed {
    logic [1:0]  flit_type; // 01:Head, 00:Body, 10:Tail
    logic [31:0] payload;   
} flit_t;

// Cấu trúc Head Flit (dùng cho giải mã)
typedef struct packed {
    logic [1:0]  flit_type;  // 2'b01
    logic [1:0]  src_x;      // Source X coordinate
    logic [1:0]  src_y;      // Source Y coordinate
    logic [1:0]  dest_x;     // Dest X coordinate
    logic [1:0]  dest_y;     // Dest Y coordinate
    logic        priority_bit; // 1:High, 0:Low
    logic        we;         // 1:Write, 0:Read
    logic [3:0]  be;         // Byte enable
    logic [18:0] reserved;
} head_flit_t;

module tb_noc_performance;

    parameter DATA_WIDTH = 34;
    parameter CLK_PERIOD = 10; // 100MHz

    logic clk;
    logic rst_n;

    // Các chân Debug để kiểm tra trạng thái CPU
    wire [31:0] pc00, alu00, pc22, alu22, dummy;

    // =======================================================
    // 1. KHỞI TẠO DUT (Mạng NoC Mesh 3x3)
    // =======================================================
    mesh_3x3 #(
        .DATA_WIDTH(DATA_WIDTH)
    ) dut (
        .clk(clk),
        .rst_n(rst_n),
        .fmax_pc_00(pc00),   // PC của CPU 0
        .fmax_alu_00(alu00), // ALU của CPU 0
        .fmax_pc_22(pc22),   // PC của CPU 1
        .fmax_alu_22(alu22), // ALU của CPU 1
        .dummy_output(dummy)
    );

    // =======================================================
    // 2. TẠO XUNG NHỊP & RESET
    // =======================================================
    initial begin
        clk = 0;
        forever #(CLK_PERIOD/2) clk = ~clk;
    end

    initial begin
        rst_n = 0;
        #(CLK_PERIOD * 5);
        rst_n = 1;
        $display("\n[%0t] He thong NoC da duoc Reset, bat dau chay...", $time);
    end

    // =======================================================
    // 3. LOGIC "RÌNH" GÓI TIN (Probing)
    // =======================================================
    // Monitor cổng East của CPU 0 (0,0)
    wire valid_out_00_e = dut.e_valid_out[0][0];
    wire credit_in_00_e = dut.MESH_X[1].MESH_Y[0].in_w_c;
    head_flit_t head_out_00_e;
    assign head_out_00_e = head_flit_t'(dut.e_flit_out[0][0]);

    // Monitor cổng West của CPU 1 (2,2)
    wire valid_out_22_w = dut.w_valid_out[2][2];

    // =======================================================
    // 4. KỊCH BẢN KIỂM THỬ (Test Procedure)
    // =======================================================
    initial begin
        // --- BƯỚC 1: Đợi CPU 0 tính và gửi TỔNG CHẴN ---
        $display("-------------------------------------------------------");
        $display("[%0t] Dang doi CPU 0 (0,0) tinh Tong Chan...", $time);
        
        // Đợi đến khi CPU 0 phát valid ra cổng East (nghĩa là bắt đầu gửi gói tin)
        wait (valid_out_00_e); 
        $display("[%0t] -> CPU 0 da tinh xong va bat dau gui goi tin ghi vao RAM!", $time);
        $display("[%0t]    ALU cua CPU 0 hien tai: %0d", $time, alu00);

        // --- BƯỚC 2: Đợi CPU 1 tính và gửi TỔNG LẺ ---
        $display("\n[%0t] Dang doi CPU 1 (2,2) tinh Tong Le...", $time);
        
        // Đợi đến khi CPU 1 phát valid ra cổng West (bắt đầu gửi gói tin)
        wait (valid_out_22_w);
        $display("[%0t] -> CPU 1 da tinh xong va bat dau gui goi tin ghi vao RAM!", $time);
        $display("[%0t]    ALU cua CPU 1 hien tai: %0d", $time, alu22);

        // --- BƯỚC 3: Đợi Mạng NoC Vận Chuyển Dữ Liệu ---
        $display("\n[%0t] Cho mang NoC dinh tuyen va ghi du lieu vao Slave RAM...", $time);
        #(CLK_PERIOD * 50); // Cho mạng 50 chu kỳ để giải quyết tắc nghẽn và ghi xong

        // --- BƯỚC 4: BÁO CÁO KẾT QUẢ TỪ SHARED RAM ---
        $display("\n=======================================================");
        $display("   BAO CAO KET QUA TINH TOAN DA LOI (MULTI-CORE)");
        $display("=======================================================");
        
        // Kiểm tra Ô nhớ 0 (Dữ liệu của CPU 0)
        $display("1. KIEM TRA TONG CHAN (Tu CPU 0):");
        if (dut.MESH_X[1].MESH_Y[1].NODE_RAM_11.u_slave.memory[0] == 30)
            $display("   -> [PASSED] RAM nhan dung ket qua: 30");
        else
            $display("   -> [FAILED] RAM nhan sai: %0d (Mong doi: 30)", dut.MESH_X[1].MESH_Y[1].NODE_RAM_11.u_slave.memory[0]);

        // Kiểm tra Ô nhớ 1 (Dữ liệu của CPU 1)
        $display("2. KIEM TRA TONG LE (Tu CPU 1):");
        if (dut.MESH_X[1].MESH_Y[1].NODE_RAM_11.u_slave.memory[1] == 25)
            $display("   -> [PASSED] RAM nhan dung ket qua: 25");
        else
            $display("   -> [FAILED] RAM nhan sai: %0d (Mong doi: 25)", dut.MESH_X[1].MESH_Y[1].NODE_RAM_11.u_slave.memory[1]);

        // --- BƯỚC 5: KIỂM TRA ĐỘ ƯU TIÊN VÀ NGHẼN MẠNG ---
        $display("\n3. THONG SO MANG (NETWORK METRICS):");
        if (head_out_00_e.priority_bit == 1'b0)
            $display("   - Priority cua CPU 0: LOW (0)");
        else
            $display("   - Priority cua CPU 0: HIGH (1)");

        if (credit_in_00_e == 1'b0)
            $display("   - Tinh trang link CPU 0: CO NGHEN (Stall phat hien)");
        else
            $display("   - Tinh trang link CPU 0: THONG SUOT");

        $display("=======================================================");
        $finish;
    end

endmodule